{% extends "layouts/slide.njk" %}
{% from "partials/field.njk" import field %}

{% block slide %}
<section class="slide s-demo" data-recipe="{{ recipe }}" data-label="{{ label }}">
  <h2>{{ field(fields, "title", effectiveMode) | safe }}</h2>
  <div class="browser">
    <div class="chrome">
      <div class="dots"><span class="r"></span><span class="y"></span><span class="g"></span></div>
      <div class="url"><span class="lock">⚲</span>{{ field(fields, "url", effectiveMode) | safe }}</div>
      <div></div>
    </div>
    <div class="body">
      <div class="sidebar">
        {% for item in sidebar %}<div class="item{% if item.active %} active{% endif %}">{{ item.label }}</div>{% endfor %}
      </div>
      <div class="main">
        <h3>{{ field(fields, "main_title", effectiveMode) | safe }}</h3>
        <div class="sub">{{ field(fields, "main_sub", effectiveMode) | safe }}</div>
        <div class="cards">
          {% for c in cards %}<div class="c c{{ loop.index }}"><div class="k">{{ c.k }}</div><div class="v">{{ c.v }}</div></div>{% endfor %}
        </div>
      </div>
    </div>
  </div>
  <span class="sl-label">{{ order }} · {{ label }}</span>
</section>
{% endblock %}
