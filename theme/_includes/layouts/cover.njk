{% extends "layouts/slide.njk" %}
{% from "partials/field.njk" import field %}

{% block slide %}
<section class="slide s-cover" data-recipe="{{ recipe }}" data-label="{{ label }}">
  {% if fields.bg_image %}
  <div class="bg-image">
    {{ field(fields, "bg_image", effectiveMode) | safe }}
  </div>
  {% endif %}
  
  {% if fields.logo %}
  <div class="conf-logo">
    {{ field(fields, "logo", effectiveMode) | safe }}
  </div>
  {% endif %}

  {% if fields.kicker %}<div class="kicker">{{ field(fields, "kicker", effectiveMode) | safe }}</div>{% endif %}
  <h1>{{ field(fields, "title", effectiveMode) | safe }}</h1>
  {% if fields.deck %}<div class="deck">{{ field(fields, "deck", effectiveMode) | safe }}</div>{% endif %}

  <div class="author-footer">
    with <img class="heart-mark" src="{{ '/talks/assets/heart.svg' | url }}" alt="love"> by <strong>Nicolás Patarino</strong> <img class="ar-flag" src="{{ '/talks/assets/argentina.svg' | url }}" alt="Argentina"><img class="cc-mark" src="{{ '/talks/assets/chimichurri-code.svg' | url }}" alt="Chimichurri Code">
  </div>

  <span class="sl-label">{{ order }} · {{ label }}</span>
</section>
{% endblock %}
