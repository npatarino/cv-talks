{% extends "layouts/slide.njk" %}
{% from "partials/field.njk" import field %}

{% block slide %}
{% set v = variant or "default" %}
<section class="slide s-big-concept{% if v != 'default' %} {{ v }}{% endif %}" data-recipe="{{ recipe }}" data-label="{{ label }}">
  {% if fields.icon and fields.icon.content %}
    {%- if iconTint and effectiveMode != "meta" -%}
  {# Opt-in tint: turn each <img> into a masked span so the icon renders as a
     solid silhouette in --recipe-ink (matches the title color). #}
  <div class="concept-icon">{{ fields.icon.content | replace(r/<img\b[^>]*?src="([^"]+)"[^>]*>/g, '<span class="concept-icon-tint" style="-webkit-mask-image:url($1);mask-image:url($1)"></span>') | safe }}</div>
    {%- else -%}
  {# Default: keep each icon's own colors. #}
  <div class="concept-icon">{{ field(fields, "icon", effectiveMode) | safe }}</div>
    {%- endif -%}
  {% endif %}
  {% if v == "divider" %}
    <h2>{{ field(fields, "title", effectiveMode) | safe }}</h2>
    {% if fields.sub %}<div class="sub">{{ field(fields, "sub", effectiveMode) | safe }}</div>{% endif %}
  {% elif v == "transition" %}
    <h2>{{ field(fields, "title", effectiveMode) | safe }}</h2>
  {% elif v == "prompt" %}
    <h2>{{ field(fields, "title", effectiveMode) | safe }}</h2>
  {% else %}
    <h1>{{ field(fields, "title", effectiveMode) | safe }}</h1>
    {% if fields.note %}<div class="note">{{ field(fields, "note", effectiveMode) | safe }}</div>{% endif %}
  {% endif %}
  <span class="sl-label{% if v == 'default' or v == 'divider' or v == 'takeaway' %} dark{% endif %}">{{ order }} · {{ label }}</span>
</section>
{% endblock %}
