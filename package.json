{
  "name": "@chimichurricode/talks",
  "version": "0.1.0",
  "private": true,
  "description": "Chimichurri Code — modular slide system (Eleventy).",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "sync:fonts": "node scripts/sync-fonts.mjs",
    "build": "bun run sync:fonts && eleventy && bun scripts/build-seo.mjs",
    "serve": "bun run sync:fonts && eleventy --serve",
    "serve:meta": "bun run sync:fonts && SLIDE_MODE=meta eleventy --serve",
    "editor": "bun editor/server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "format": "bun scripts/format-decks.mjs",
    "format:check": "bun scripts/format-decks.mjs --check"
  },
  "dependencies": {
    "@chimichurricode/design-system": "^0.7.3",
    "@chimichurricode/analytics": "^0.1.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "vitest": "^4.1.7"
  }
}
